# ==============================================================================
# Paperclip — exemplo de variaveis de ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env preenchido.
# ==============================================================================

# ------------------------------------------------------------------------------
# Core (obrigatorio)
# ------------------------------------------------------------------------------

# String de conexao Postgres. Deixe em branco para usar PGlite embedded em dev.
# Em producao (Railway/VPS/Supabase), use Postgres gerenciado.
# Se usar pooler Supabase (porta 6543), editar packages/db/src/client.ts
# para `postgres(url, { prepare: false })`.
DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip

# Porta de escuta do servidor. Railway injeta $PORT automaticamente.
PORT=3100

# Servir UI (React) no mesmo processo da API. true em producao single-service.
SERVE_UI=true

# Chave de assinatura do Better Auth. Gerar com: openssl rand -base64 48
# Minimo 32 caracteres. NAO reutilizar entre ambientes.
BETTER_AUTH_SECRET=troque-me-gerar-com-openssl-rand-base64-48

# Modo de deployment.
# - local_trusted: sem login (so usar em dev local)
# - authenticated: exige login (usar em producao)
PAPERCLIP_DEPLOYMENT_MODE=authenticated

# URL publica (usada em redirects de auth, webhooks, etc).
PAPERCLIP_PUBLIC_URL=https://painel.jotabot.site

# ------------------------------------------------------------------------------
# LLM providers (preencher os que voce usa)
# ------------------------------------------------------------------------------

# OpenAI (Codex local adapter)
OPENAI_API_KEY=

# Google Gemini (gemini-local adapter)
GEMINI_API_KEY=

# Anthropic Claude (opcional, claude-local adapter)
ANTHROPIC_API_KEY=

# ------------------------------------------------------------------------------
# Integracao Lever - webhook inbound (Lever -> Paperclip)
# ------------------------------------------------------------------------------

# Bearer token que o Lever envia em Authorization. Gerar: openssl rand -hex 32
WEBHOOK_SECRET=

# ------------------------------------------------------------------------------
# Integracao Lever - client outbound (Paperclip -> Edge Function Supabase)
# ------------------------------------------------------------------------------

# URL da Edge Function paperclip-inbound no Supabase do Lever.
LEVER_INBOUND_URL=https://<projeto-lever>.supabase.co/functions/v1/paperclip-inbound

# Bearer que a Edge Function valida (precisa bater com PAPERCLIP_WEBHOOK_SECRET
# configurado nos secrets da Edge Function no Supabase).
LEVER_INBOUND_BEARER=

# JWT anon do projeto Supabase do Lever (publishable key).
LEVER_ANON_KEY=

# Identificador do ator quando Paperclip registra acoes no activity log do Lever.
LEVER_DEFAULT_ACTOR=paperclip-orchestrator

# ------------------------------------------------------------------------------
# Infra / producao (opcional)
# ------------------------------------------------------------------------------

NODE_ENV=production

# Backup automatico do banco embedded (so relevante se usar PGlite em prod - nao recomendado)
PAPERCLIP_DB_BACKUP_ENABLED=false
PAPERCLIP_DB_BACKUP_INTERVAL_MINUTES=60
PAPERCLIP_DB_BACKUP_RETENTION_DAYS=7

# Heartbeat scheduler (acorda agentes periodicamente). true em producao.
HEARTBEAT_SCHEDULER_ENABLED=true
